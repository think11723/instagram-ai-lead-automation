    {
      "id": "136d7bfe-3464-41a7-9240-fc579c178bc5",
      "name": "Deterministic Spam Filter",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3600, -120],
      "parameters": {
        "jsCode": "const text = $json.commentTextLower || '';\n\nconst spamPatterns = [\n  /crypto/, /forex/, /casino/, /investment/, /invest now/,\n  /t\\.me\\//, /telegram/, /whatsapp/, /\\+?\\d[\\d\\s\\-]{7,}\\d/, // phone-like numbers\n  /discount code/, /limited offer/, /click the link/,\n  /https?:\\/\\//, /www\\./\n];\n\nconst isSpam = spamPatterns.some(pattern => pattern.test(text));\n\nreturn [{\n  json: {\n    ...$json,\n    isSpam\n  }\n}];"
