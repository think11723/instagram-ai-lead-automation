      "parameters": {
        "jsCode": "// One reusable prompt builder feeds a single shared \"Generate AI Reply\" HTTP node,\n// instead of duplicating the HTTP config four times. Rewritten to sound like a real\n// creator, not a support bot: max one emoji, no hashtags, no quotation marks, no\n// \"as an AI\" language, no corporate tone.\nconst type = ($json.classification && $json.classification.type) || 'unknown';\n\nconst PROMPTS = {\n  positive: \"Someone left a nice comment on your Instagram post. Reply like you're genuinely happy about it - casual, warm, like a real person typing fast, not a brand account. One sentence, max 20 words. At most one emoji. No hashtags, no quotation marks around the reply.\",\n  negative: \"Someone left a critical or negative comment on your Instagram post. Reply calmly and respectfully, acknowledge their point, apologize briefly if it fits. Max 25 words. At most one emoji, and only if it genuinely fits - it's fine to use none. No hashtags, no quotation marks, no corporate language.\",\n  question: \"Someone asked a question in the comments on your Instagram post. Answer it directly and helpfully like you actually know the answer, in your own casual voice. Max 25 words. At most one emoji. No hashtags, no quotation marks.\",\n  unknown: \"Someone left a comment on your Instagram post that doesn't clearly fall into a category. Write a short, friendly, natural reply acknowledging it. Max 20 words. At most one emoji. No hashtags, no quotation marks, no generic corporate language.\"\n};\n\nconst systemPrompt = PROMPTS[type] || PROMPTS.unknown;\n\nreturn [{\n  json: {\n    ...$json,\n    systemPrompt\n  }\n}];"
      }
    },
