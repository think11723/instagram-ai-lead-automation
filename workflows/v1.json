    {
      "id": "f073f108-145d-4da9-9846-a885f9e61a73",
      "name": "Deterministic Profanity Filter",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3160, -120],
      "parameters": {
        "jsCode": "// Lightweight deterministic profanity check. Extend this list as needed; keep it out\n// of source control policy discussions - it's intentionally short/generic here.\nconst abusiveWords = [\n  'fuck', 'shit', 'bitch', 'asshole', 'bastard', 'slut', 'whore', 'cunt'\n];\n\nconst text = $json.commentTextLower || '';\nconst isProfane = abusiveWords.some(word => text.includes(word));\n\nreturn [{\n  json: {\n    ...$json,\n    isProfane\n  }\n}];"
