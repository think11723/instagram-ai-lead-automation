      "id": "5abeab1f-1184-4c44-836c-a2e9bab62408",
      "name": "Evaluate Cooldown",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2720, -120],
      "parameters": {
        "jsCode": "// Configurable cooldown window; defaults to 60 minutes if the env var is unset/invalid.\nconst cooldownMinutes = Number($env.USER_REPLY_COOLDOWN_MINUTES) || 60;\nconst rows = $input.all().map(item => item.json);\nconst current = $('Store Comment ID').first().json;\n\nlet mostRecentReplyMs = 0;\nfor (const row of rows) {\n  if (!row.timestamp) continue;\n  const t = Date.parse(row.timestamp);\n  if (!isNaN(t) && t > mostRecentReplyMs) mostRecentReplyMs = t;\n}\n\nconst withinCooldown = mostRecentReplyMs > 0 &&\n  (Date.now() - mostRecentReplyMs) < (cooldownMinutes * 60 * 1000);\n\nreturn [{\n  json: {\n    ...current,\n    recentlyReplied: withinCooldown\n  }\n}];"
      }
    },
