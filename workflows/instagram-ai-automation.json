        "jsCode": "const KEYWORDS = [\n  'pdf', 'guide', 'ebook', 'resource', 'course', 'price', 'pricing',\n  'details', 'link', 'dm', 'buy', 'template', 'checklist'\n];\n\nconst text = $json.commentTextLower || '';\nconst matched = KEYWORDS.find(word => text.includes(word)) || null;\n\nreturn [{\n  json: {\n    ...$json,\n    keywordMatch: matched,\n    isKeywordMatch: matched !== null\n  }\n}];"
