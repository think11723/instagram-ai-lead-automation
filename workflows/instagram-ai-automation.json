    {
      "parameters": {
        "jsCode": "// Cooldown in minutes (default 60)\nconst cooldownMinutes = Number($env.USER_REPLY_COOLDOWN_MINUTES) || 60;\n\n// Rows returned by Google Sheets\nconst historyRows = $input.all().map(i => i.json);\n\n// Original Instagram comment\nconst current = $('Code in JavaScript').first().json;\n\n// Find latest reply timestamp\nlet latestReply = 0;\n\nfor (const row of historyRows) {\n  if (!row.timestamp) continue;\n\n  const ts = Date.parse(row.timestamp);\n\n  if (!Number.isNaN(ts) && ts > latestReply) {\n    latestReply = ts;\n  }\n}\n\n// Check cooldown\nconst recentlyReplied =\n  latestReply > 0 &&\n  (Date.now() - latestReply) < cooldownMinutes * 60 * 1000;\n\n// Return original data + cooldown flag\nreturn [\n  {\n    json: {\n      ...current,\n      recentlyReplied,\n      lastReplyTimestamp:\n        latestReply > 0\n          ? new Date(latestReply).toISOString()\n          : null\n    }\n  }\n];"
      },
      "id": "c9283134-4548-4427-991a-17996405a28e",
