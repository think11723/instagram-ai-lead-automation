      "id": "2a250da8-220d-4cb8-a62d-ef83c73cbae6",
      "name": "Generate AI Reply",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2608,
        656
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 1000,
      "continueOnFail": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const fallback = 'Thanks for your comment! \\ud83d\\ude0a';\nlet aiReply = fallback;\nlet aiSuccess = true;\nlet replySource = 'ai';\n\nconst hadError = $json.error !== undefined;\nconst upstream = $('Build Reply Prompt').first().json;\nconst modelUsed = $env.OPENROUTER_MODEL || 'openai/gpt-oss-20b:free';\n\nif (hadError) {\n  aiSuccess = false;\n  replySource = 'fallback';\n} else {\n  try {\n    const content = $json.choices[0].message.content;\n    aiReply = String(content).trim().replace(/^\"|\"$/g, '');\n    if (!aiReply) {\n      aiReply = fallback;\n      aiSuccess = false;\n      replySource = 'fallback';\n    }\n  } catch (e) {\n    aiReply = fallback;\n    aiSuccess = false;\n    replySource = 'fallback';\n  }\n}\n\nreturn [{\n  json: {\n    ...upstream,\n    aiReply,\n    aiSuccess,\n    replySource,\n    aiModel: modelUsed\n  }\n}];"
      },
