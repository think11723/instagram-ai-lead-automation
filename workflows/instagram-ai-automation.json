        "jsCode": "const current = $('Normalize Comment Data').first().json;\n\nconst rows = $input.all();\n\n// A real duplicate exists only if at least one returned item\n// has one or more properties.\nconst isDuplicate = rows.some(item => Object.keys(item.json || {}).length > 0);\n\nreturn [{\n  json: {\n    ...current,\n    isDuplicate\n  }\n}];"
