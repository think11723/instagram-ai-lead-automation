        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  model: \"openai/gpt-oss-20b:free\",\n  messages: [\n    {\n      role: \"system\",\n      content: \"You are a strict JSON-only classifier for Instagram comments. Read the comment and respond with ONLY one JSON object, no prose, no markdown, no code fences. Choose exactly one of these shapes: {\\\"type\\\":\\\"positive\\\"}, {\\\"type\\\":\\\"negative\\\"}, {\\\"type\\\":\\\"question\\\"}, {\\\"type\\\":\\\"unknown\\\"}. Keyword requests and spam are already filtered out before this step, so never return \\\"keyword\\\" or \\\"spam\\\". Return nothing except the JSON object.\"\n    },\n    {\n      role: \"user\",\n      content: $json.commentText\n    }\n  ],\n  temperature: 0.2\n}) }}",
        "options": {
          "timeout": 15000
        }
      },
      "id": "606e65c3-0721-483a-a518-7d89e1be7bf3",
      "name": "Classify Comment",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2016,
        672
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 1000,
      "continueOnFail": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const upstream = $('Deterministic Keyword Detector').first().json;\nlet classification = { type: 'unknown' };\nconst hadError = $json.error !== undefined;\n\nif (!hadError) {\n  try {\n    const content = $json.choices[0].message.content;\n    const cleaned = String(content).trim().replace(/^```json/i, '').replace(/```$/, '').trim();\n    const parsed = JSON.parse(cleaned);\n    if (parsed && typeof parsed.type === 'string') {\n      classification = parsed;\n    }\n  } catch (e) {\n    classification = { type: 'unknown' };\n  }\n}\n\nreturn [{\n  json: {\n    ...upstream,\n    classification,\n    classifyCallFailed: hadError\n  }\n}];"
      },
      "id": "699af1a8-a764-47a7-8810-6f00cd9ca758",
      "name": "Parse Classification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2336,
        864
      ]
    },
    {
      "parameters": {
        "jsCode": "// One reusable prompt builder feeds a single shared \"Generate AI Reply\" HTTP node,\n// instead of duplicating the HTTP config four times. Rewritten to sound like a real\n// creator, not a support bot: max one emoji, no hashtags, no quotation marks, no\n// \"as an AI\" language, no corporate tone.\nconst type = ($json.classification && $json.classification.type) || 'unknown';\n\nconst PROMPTS = {\n  positive: \"Someone left a nice comment on your Instagram post. Reply like you're genuinely happy about it - casual, warm, like a real person typing fast, not a brand account. One sentence, max 20 words. At most one emoji. No hashtags, no quotation marks around the reply.\",\n  negative: \"Someone left a critical or negative comment on your Instagram post. Reply calmly and respectfully, acknowledge their point, apologize briefly if it fits. Max 25 words. At most one emoji, and only if it genuinely fits - it's fine to use none. No hashtags, no quotation marks, no corporate language.\",\n  question: \"Someone asked a question in the comments on your Instagram post. Answer it directly and helpfully like you actually know the answer, in your own casual voice. Max 25 words. At most one emoji. No hashtags, no quotation marks.\",\n  unknown: \"Someone left a comment on your Instagram post that doesn't clearly fall into a category. Write a short, friendly, natural reply acknowledging it. Max 20 words. At most one emoji. No hashtags, no quotation marks, no generic corporate language.\"\n};\n\nconst systemPrompt = PROMPTS[type] || PROMPTS.unknown;\n\nreturn [{\n  json: {\n    ...$json,\n    systemPrompt\n  }\n}];"
      },
      "id": "f271f58c-bd7a-4b44-9d38-a8bdb023ef9f",
      "name": "Build Reply Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2384,
        656
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "YOUR_OPENROUTER_API_KEY"
            },
            {
              "name": "HTTP-Referer",
              "value": "http://localhost"
            },
            {
              "name": "X-Title",
              "value": "Instagram AI Automation"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: $env.OPENROUTER_MODEL || \"openai/gpt-oss-20b:free\", messages: [ { role: \"system\", content: $json.systemPrompt }, { role: \"user\", content: $json.commentText } ], temperature: 0.8 }) }}",
        "options": {
