    {
      "parameters": {
        "jsCode": "const body = $json.body || {};\n\n// Real Meta webhook\nif (body.entry) {\n  const entry = body.entry[0] || {};\n  const change = (entry.changes || [])[0] || {};\n  const value = change.value || {};\n\n  return [{\n    json: {\n      raw: value\n    }\n  }];\n}\n\n// Local Postman testing\nif (body.raw) {\n  return [{\n    json: {\n      raw: body.raw\n    }\n  }];\n}\n\nthrow new Error(\"No comment payload found.\");"
      },
      "id": "91c18bd5-38dd-421f-ac8a-a91e6e676646",
      "name": "Extract Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1648,
        272
      ]
    },
    {
      "parameters": {
        "jsCode": "const v = $input.first().json.raw;\n\nconst commentId = v.id || v.comment_id || '';\nconst mediaId = (v.media && v.media.id) || v.media_id || '';\nconst username = (v.from && v.from.username) || 'unknown';\nconst userId = (v.from && v.from.id) || '';\nconst commentText = v.text || '';\nconst commentTextLower = commentText.toLowerCase();\nconst timestamp = new Date().toISOString();\nconst startTime = Date.now();\n\nreturn [{\n  json: {\n    commentId,\n    mediaId,\n    username,\n    userId,\n    commentText,\n    commentTextLower,\n    timestamp,\n    startTime\n  }\n}];"
      },
