        "jsCode": "// Deterministic DM copy - varied slightly by keyword so it doesn't read as a bot template.\n// No OpenRouter call here by design (cost optimization: only ambiguous comments reach AI).\nconst leadMagnetUrl = $env.LEAD_MAGNET_URL || '';\nconst keyword = $json.keywordMatch || 'that';\n\nconst templates = [\n  `Hey! Here's the ${keyword} you asked about: ${leadMagnetUrl}`,\n  `Got you - here's the link: ${leadMagnetUrl}`,\n  `Sending it over now: ${leadMagnetUrl}`\n];\n\nconst dmMessage = templates[Math.floor(Math.random() * templates.length)];\n\nreturn [{\n  json: {\n    ...$json,\n    aiReply: 'Thanks! Check your DMs \\ud83d\\ude0a',\n    dmMessage,\n    replySource: 'keyword',\n    aiModel: '',\n    aiSuccess: false\n  }\n}];"
      },
      "id": "a31f4883-b81f-45ef-ba43-d2006e979c6c",
      "name": "Build Keyword Reply + DM",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2608,
        464
      ]
    },
    {
      "parameters": {
        "method": "POST",
